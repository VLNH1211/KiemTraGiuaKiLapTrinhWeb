@model KiemTraGiuaKy.Models.Course
@{
    ViewData["Title"] = "Chỉnh sửa Học phần";
}

<div class="page-header">
    <h1><i class="bi bi-pencil-square me-2"></i>Chỉnh sửa Học phần</h1>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-body p-4">
                <form asp-action="Edit" method="post" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="Image" />

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label">Tên học phần</label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Credits" class="form-label">Số tín chỉ</label>
                            <input asp-for="Credits" class="form-control" type="number" min="1" max="10" />
                            <span asp-validation-for="Credits" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="CategoryId" class="form-label">Danh mục</label>
                            <select asp-for="CategoryId" asp-items="@(ViewBag.Categories as SelectList)" class="form-select">
                            </select>
                            <span asp-validation-for="CategoryId" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Lecturer" class="form-label">Giảng viên</label>
                        <input asp-for="Lecturer" class="form-control" />
                        <span asp-validation-for="Lecturer" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Hình ảnh hiện tại</label>
                        @if (!string.IsNullOrEmpty(Model.Image))
                        {
                            <div class="mb-2">
                                <img src="@Model.Image" alt="@Model.Name" 
                                     style="max-width: 200px; border-radius: 8px;" />
                            </div>
                        }
                        <input type="file" name="imageFile" class="form-control" accept="image/*" />
                        <small class="text-muted">Chọn file mới để thay đổi hình ảnh</small>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-lg me-1"></i> Lưu thay đổi
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left me-1"></i> Quay lại
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
