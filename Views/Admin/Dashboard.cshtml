@{
    ViewData["Title"] = "Admin Dashboard";
    var courseNames = ViewBag.CourseNames as List<string> ?? new List<string>();
    var courseCounts = ViewBag.CourseCounts as List<int> ?? new List<int>();
    var categoryNames = ViewBag.CategoryNames as List<string> ?? new List<string>();
    var categoryCounts = ViewBag.CategoryCounts as List<int> ?? new List<int>();
}

<div class="page-header">
    <h1><i class="bi bi-speedometer2 me-2"></i>Admin Dashboard</h1>
</div>

<!-- Stat Cards -->
<div class="row g-4 mb-4">
    <div class="col-md-4">
        <div class="stat-card stat-courses">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <div class="stat-number">@ViewBag.TotalCourses</div>
                    <div class="stat-label">Tổng số Học phần</div>
                </div>
                <div class="stat-icon">
                    <i class="bi bi-book-half"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="stat-card stat-students">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <div class="stat-number">@ViewBag.TotalStudents</div>
                    <div class="stat-label">Tổng số Sinh viên</div>
                </div>
                <div class="stat-icon">
                    <i class="bi bi-people-fill"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="stat-card stat-enrollments">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <div class="stat-number">@ViewBag.TotalEnrollments</div>
                    <div class="stat-label">Tổng số Lượt đăng ký</div>
                </div>
                <div class="stat-icon">
                    <i class="bi bi-clipboard-check-fill"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Charts -->
<div class="row g-4">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title mb-3">
                    <i class="bi bi-bar-chart-fill text-primary me-2"></i>Lượt đăng ký theo Học phần
                </h5>
                <div style="position: relative; height: 350px; width: 100%;">
                    <canvas id="enrollmentChart"></canvas>
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title mb-3">
                    <i class="bi bi-pie-chart-fill text-secondary me-2"></i>Theo Danh mục
                </h5>
                <div style="position: relative; height: 350px; width: 100%;">
                    <canvas id="categoryChart"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Quick Actions -->
<div class="row mt-4">
    <div class="col-12">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title mb-3"><i class="bi bi-lightning-fill text-warning me-2"></i>Thao tác nhanh</h5>
                <div class="d-flex gap-2 flex-wrap">
                    <a asp-action="Index" class="btn btn-outline-primary">
                        <i class="bi bi-list-ul me-1"></i> Quản lý Học phần
                    </a>
                    <a asp-action="Create" class="btn btn-outline-success">
                        <i class="bi bi-plus-lg me-1"></i> Thêm Học phần
                    </a>
                    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">
                        <i class="bi bi-house me-1"></i> Trang chủ
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script>
        // Bar Chart - Enrollments per Course
        var ctx1 = document.getElementById('enrollmentChart').getContext('2d');
        new Chart(ctx1, {
            type: 'bar',
            data: {
                labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(courseNames)),
                datasets: [{
                    label: 'Lượt đăng ký',
                    data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(courseCounts)),
                    backgroundColor: [
                        'rgba(67, 97, 238, 0.8)',
                        'rgba(114, 9, 183, 0.8)',
                        'rgba(247, 37, 133, 0.8)',
                        'rgba(6, 214, 160, 0.8)',
                        'rgba(255, 209, 102, 0.8)',
                        'rgba(239, 71, 111, 0.8)',
                        'rgba(58, 12, 163, 0.8)',
                        'rgba(26, 26, 46, 0.8)',
                        'rgba(5, 192, 144, 0.8)',
                        'rgba(214, 31, 105, 0.8)'
                    ],
                    borderRadius: 8,
                    borderSkipped: false
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: { stepSize: 1 }
                    },
                    x: {
                        ticks: {
                            maxRotation: 45,
                            font: { size: 11 }
                        }
                    }
                }
            }
        });

        // Doughnut Chart - Enrollments per Category
        var ctx2 = document.getElementById('categoryChart').getContext('2d');
        new Chart(ctx2, {
            type: 'doughnut',
            data: {
                labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(categoryNames)),
                datasets: [{
                    data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(categoryCounts)),
                    backgroundColor: [
                        'rgba(67, 97, 238, 0.85)',
                        'rgba(6, 214, 160, 0.85)',
                        'rgba(247, 37, 133, 0.85)',
                        'rgba(114, 9, 183, 0.85)',
                        'rgba(255, 209, 102, 0.85)'
                    ],
                    borderWidth: 2,
                    borderColor: '#fff'
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        position: 'bottom',
                        labels: { padding: 15 }
                    }
                }
            }
        });
    </script>
}
